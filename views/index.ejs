<div class="container-lg">
    <% if (locals.messages && messages.length > 0) { %>
        <ul class="list-group">
            <% messages.forEach((message) => { %>
                <li class="list-group-item p-0 border-0 mb-3 rounded-4">
                    <div class="card rounded-4">
                        <div class="p-3"><%= message.message %></div>
                        <% if (locals.currentUser && currentUser.membership_id === 2) { %>
                             <div class="card-footer text-body-secondary d-flex justify-content-between">
                                <div><%= message.author_name %></div>
                                <div><%= formatDistance(message.created_at, new Date(), {includeSeconds: true}) %></div>
                            </div>
                        <% } %>
                        <% if (locals.currentUser && currentUser.is_admin === true) { %>
                                <form action="/delete/<%= message.id %>" method="post">
                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete the message?')">Delete</button>
                                </form>
                        <% } %>
                    </div>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <div>No messages</div>
    <% } %>
</div>
